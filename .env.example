# bhAI Voice Bot Configuration
# Copy this file to .env and fill in your API keys

# LLM Backend: "sarvam" (default), "openai", or "claude"
LLM_BACKEND=sarvam

# Sarvam AI (required for STT/TTS; also used for LLM when LLM_BACKEND=sarvam)
SARVAM_API_KEY=...
SARVAM_LLM_MODEL=sarvam-105b
SARVAM_LLM_URL=https://api.sarvam.ai/v1
SARVAM_STT_MODEL=saaras:v3
SARVAM_TTS_VOICE=manisha
SARVAM_TTS_LANGUAGE=hi-IN

# OpenAI (only needed when LLM_BACKEND=openai)
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini

# Claude / Anthropic (only needed when LLM_BACKEND=claude)
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# ElevenLabs TTS (when TTS_BACKEND=elevenlabs)
# TTS_BACKEND=elevenlabs
# ELEVENLABS_API_KEY=sk_...
# ELEVENLABS_VOICE_ID=...

# Twilio WhatsApp (for webhook)
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886
BASE_URL=https://your-ngrok-url.ngrok-free.app

# Encryption (required for conversation memory and user profiles)
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
BHAI_ENCRYPTION_KEY=...

# Escalation emails (Resend HTTPS API) — sent when the LLM emits
# `ESCALATE: true`. Auto-disables if RESEND_API_KEY is empty. SMTP
# doesn't work from Railway (outbound ports blocked); Resend's HTTPS
# API does. Free tier: 3,000/month, 100/day.
#
# RESEND_FROM_EMAIL defaults to onboarding@resend.dev which works
# without any DNS setup but ONLY sends to the email address that owns
# the Resend account. To send to anyone, verify tinymiracles.com in
# Resend dashboard (add SPF + DKIM TXT records) and set
# RESEND_FROM_EMAIL=bhai@tinymiracles.com (or similar).
# RESEND_API_KEY=re_xxxxxxxxxxxx
# RESEND_FROM_EMAIL=onboarding@resend.dev
# ESCALATION_RECIPIENTS=rishikesh@tinymiracles.com,anu@tinymiracles.com
# ESCALATION_ENABLED=true
