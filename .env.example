# bhAI Voice Bot Configuration
# Copy this file to .env and fill in your API keys

# LLM Backend: "sarvam" (default), "openai", or "claude"
LLM_BACKEND=sarvam

# Sarvam AI (required for STT/TTS; also used for LLM when LLM_BACKEND=sarvam)
SARVAM_API_KEY=...
SARVAM_LLM_MODEL=sarvam-105b
SARVAM_LLM_URL=https://api.sarvam.ai/v1
SARVAM_STT_MODEL=saaras:v3
SARVAM_TTS_VOICE=manisha
SARVAM_TTS_LANGUAGE=hi-IN

# OpenAI (only needed when LLM_BACKEND=openai)
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini

# Claude / Anthropic (only needed when LLM_BACKEND=claude)
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# ElevenLabs TTS (when TTS_BACKEND=elevenlabs)
# TTS_BACKEND=elevenlabs
# ELEVENLABS_API_KEY=sk_...
# ELEVENLABS_VOICE_ID=...

# Twilio WhatsApp (for webhook)
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886
BASE_URL=https://your-ngrok-url.ngrok-free.app

# Encryption (required for conversation memory and user profiles)
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
BHAI_ENCRYPTION_KEY=...

# Escalation emails (Gmail API + OAuth) — sent when the LLM emits
# `ESCALATE: true`. Auto-disables if any of CLIENT_ID/CLIENT_SECRET/
# REFRESH_TOKEN/SENDER_EMAIL is empty. SMTP doesn't work from Railway
# (outbound ports blocked).
#
# One-time setup:
#   1. Google Cloud Console → enable Gmail API, create OAuth Desktop client.
#      Copy client_id + client_secret into GMAIL_CLIENT_ID/GMAIL_CLIENT_SECRET.
#   2. Run: uv run python scripts/gmail_oauth_setup.py
#      Browser opens, sign in as the sender Workspace account, approve scope.
#      The script prints GMAIL_REFRESH_TOKEN + GMAIL_SENDER_EMAIL — paste both.
#   3. Mirror the four vars to Railway env vars per environment.
# GMAIL_CLIENT_ID=xxxxx.apps.googleusercontent.com
# GMAIL_CLIENT_SECRET=GOCSPX-xxxxx
# GMAIL_REFRESH_TOKEN=1//xxxxx
# GMAIL_SENDER_EMAIL=sundar@tinymiracles.com
# ESCALATION_RECIPIENTS=rishikesh@tinymiracles.com,anu@tinymiracles.com
# ESCALATION_ENABLED=true
